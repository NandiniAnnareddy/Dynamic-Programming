class Solution:
    def maxProfit(self, prices: List[int], fee: int) -> int:
        profit = 0
        buy = prices[0]
        for i in range(1,len(prices)):
            if prices[i] > buy + fee:
                profit += prices[i]-buy-fee
                buy = prices[i] - fee
            else:
                buy = min(buy,prices[i])
        return profit

