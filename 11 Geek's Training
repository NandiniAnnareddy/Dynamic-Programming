class Solution:
    def maximumPoints(self, mat):
        prev = mat[0]
        for i in range(1,len(mat)):
            curr = [0,0,0]
            curr[0] = mat[i][0] + max(prev[1],prev[2])
            curr[1] = mat[i][1] + max(prev[0],prev[2])
            curr[2] = mat[i][2] + max(prev[0],prev[1])
            prev = curr
        return max(prev)
            
                    
        
