class Solution:
    def rob(self, nums: List[int]) -> int:
        dp_arr = [0]*len(nums)
        dp_arr[0] = nums[0]
        if len(nums)> 1:
            dp_arr[1] = max(nums[0],nums[1])
            for i in range(2,len(nums)):
                dp_arr[i] = max((nums[i]+dp_arr[i-2]),dp_arr[i-1])
        return dp_arr[-1]
